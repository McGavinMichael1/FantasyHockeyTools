# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
.env
.python-version

# uv
.uv/
uv.lock

# IDE
.vscode/
.idea/

# Local git worktrees
.worktrees/

# OS
.DS_Store

# Data files
data/**/*.csv
data/processed/*.json
# Interrupted-fetch scratch files (src/dataProcessing.py checkpointing)
data/**/*.partial

# Exception: birthDates are immutable NHL API identity data, 68 KB, and
# rebuilding them costs ~2900 API calls that once hung a laptop build for 12
# hours. Committing it means a fresh clone runs the draft tools with zero API
# calls. Refresh it with scripts/build_birthdates.py when rookies are missing.
!data/raw/player_birthdates.csv
# Timestamped backups of the above -- the *.json rule misses them (they end
# in .bak-<stamp>), so without this they show up as untracked commit bait.
data/processed/*.json.bak-*
oauth2.json

# Generated plots/reports
reports/

# Frontend (Next.js)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env*.local
frontend/.test-build/

# Models (binary files - retrain locally)
models/**/*.pkl
# Claude Code local settings (personal, not shared)
.claude/settings.local.json

# Codex-targeted export of the skill library. .claude/skills/fht-* is the
# canonical copy (see CLAUDE.md); .agents/ is a generated mirror that drifts
# (stale .Codex/ path refs, missing newer skills), so it stays local.
.agents/
AGENTS.md
